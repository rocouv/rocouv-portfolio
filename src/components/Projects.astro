---
import PoEProject from "@/assets/136shots_so.webp";
import ChefcitoLP from "@/assets/640shots_so.webp";
import WeatherApp from "@/assets/988shots_so.webp";
import {
    AstroLogo,
    ChartJSLogo,
    CSSLogo,
    HTMLLogo,
    JSLogo,
    TailwindCSSLogo,
    ViteLogo,
    VueLogo,
} from "@/components/icons";

const projects = [
    {
        name: "Path of Exile - Build Selector",
        description:
            "Tool for choosing your starter build in the ARPG game Path of Exile from Grinding Gear Games.",
        technologies: [
            { name: "HTML", logo: HTMLLogo },
            { name: "JavaScript", logo: JSLogo },
            { name: "CSS", logo: CSSLogo },
            { name: "Chart.js", logo: ChartJSLogo },
        ],
        links: [
            { name: "Repo", link: "#" },
            { name: "Demo", link: "#" },
        ],
        image: PoEProject.src,
    },
    {
        name: "Chefcito Gourmet - Landing Page",
        description: "Landing page for a local fast food restaurant.",
        technologies: [
            { name: "AstroJS", logo: AstroLogo },
            { name: "ViteJS", logo: ViteLogo },
            { name: "TailwindCSS", logo: TailwindCSSLogo },
            { name: "HTML", logo: HTMLLogo },
        ],
        links: [
            { name: "Repo", link: "#" },
            { name: "Demo", link: "#" },
        ],
        image: ChefcitoLP.src,
    },
    {
        name: "Weather App",
        description:
            "Web app for seeing the weather forecast in a specific city.",
        technologies: [
            { name: "ViteJS", logo: ViteLogo },
            { name: "VueJS", logo: VueLogo },
            { name: "TailwindCSS", logo: TailwindCSSLogo },
            { name: "CSS", logo: CSSLogo },
        ],
        links: [
            { name: "Repo", link: "#" },
            { name: "Demo", link: "#" },
        ],
        image: WeatherApp.src,
    },
];
---

<section id="projects" class="w-full px-5 py-5 md:w-fit">
    <div class="mx-auto max-w-6xl">
        <h3 class="text-4xl font-bold md:text-5xl md:flex md:justify-center">
            <span
                class="bg-linear-to-r from-azureblue to-steelblue bg-clip-text text-transparent"
            >
                Projects
            </span>
        </h3>

        <div
            class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-2 xl:gap-10"
        >
            {
                projects.map((project) => (
                    <article class="group overflow-hidden rounded-4xl border border-steelblue/20 bg-aliceblue/30 shadow-[0_12px_35px_rgba(0,0,0,0.10)] transition duration-500 ease-in-out hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(0,0,0,0.16)] dark:border-aliceblue/10 dark:bg-balticblue">
                        <div class="relative overflow-hidden">
                            {project.image ? (
                                <img
                                    src={project.image}
                                    alt={project.name}
                                    class="h-100 w-full object-cover transition-transform duration-500 group-hover:scale-105 sm:h-80 lg:h-112 xl:h-128"
                                />
                            ) : (
                                <div class="h-100 w-full bg-linear-to-br from-azureblue via-steelblue to-smartblue transition-transform duration-500 group-hover:scale-105 sm:h-80 lg:h-112 xl:h-128 dark:from-steelblue dark:via-sapphiresky dark:to-balticblue" />
                            )}

                            <div class="absolute inset-0 bg-linear-to-t from-inkblack/35 via-inkblack/10 to-transparent dark:from-steelblue/35 dark:via-balticblue/10 dark:to-transparent" />
                        </div>

                        <div class="flex flex-col justify-end p-5 sm:p-6 lg:p-8 text-inkblack dark:text-aliceblue">
                            <div class="flex items-center gap-3">
                                <h4 class="text-xl font-bold sm:text-2xl lg:text-3xl">
                                    {project.name}
                                </h4>
                            </div>

                            <p class="mt-3 text-sm leading-relaxed text-inkblack/75 sm:text-base lg:text-lg dark:text-aliceblue/80">
                                {project.description}
                            </p>

                            <div class="mt-4 flex flex-wrap gap-2">
                                {project.technologies.map((tech) => {
                                    const Logo = tech.logo;

                                    return (
                                        <span class="inline-flex items-center gap-2 rounded-full border border-steelblue/15 bg-babyblueice/45 px-3 py-1 text-xs font-medium text-inkblack lg:px-4 lg:py-2 lg:text-sm dark:border-aliceblue/10 dark:bg-coolsteel/30 dark:text-aliceblue">
                                            <Logo class="h-4 w-4 shrink-0 lg:h-5 lg:w-5" />
                                            {tech.name}
                                        </span>
                                    );
                                })}
                            </div>

                            <div class="mt-5 flex flex-wrap gap-3">
                                {project.links.map((link) => (
                                    <a
                                        href={link.link}
                                        class="inline-flex items-center justify-center rounded-full bg-babyblueice px-4 py-2 text-sm font-semibold text-inkblack transition duration-300 ease-in-out hover:scale-105 hover:bg-steelblue lg:px-5 lg:py-2.5 lg:text-base dark:bg-smartblue dark:text-aliceblue dark:hover:bg-coolsteel"
                                    >
                                        {link.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
